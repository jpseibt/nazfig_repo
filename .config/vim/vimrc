"------------------------------
" Quickfix List
"
" Prepend regex to parse (%f, %l, %t, %m) compiler/linker output correctly for QFListCount()
if !exists('s:prepend_regex_errorformat')
  let s:prepend_regex_errorformat = 1
  set errorformat& " Reset errorformat to default

  " Clang/GCC
  set errorformat^=%f:%l:%c:\ %t%*[^:]:\ %m

  " MSVC Compiler (`file.cpp(#line): error C2065: ...`)
  set errorformat^=%f(%l):\ %t%*[^:]:\ %m

  " MSVC Linker (`file.obj : error LNK2019: ...`)
  set errorformat^=%f\ :\ %t%*[^:]:\ %m

  " MSVC Linker Fatal (`file.obj : fatal error LNK2019: ...`)
  set errorformat^=%f\ :\ fatal\ %t%*[^:]:\ %m
endif

if !exists('s:qf_entries')
  let s:qf_entries = 0
  let s:qf_errors = 0
  let s:qf_warnings = 0
endif

function! s:QFListCount()
  let l:qf_list = getqflist()

  let l:entries = 0
  let l:errors = 0
  let l:warnings = 0

  for l:item in l:qf_list
    if l:item.valid
      let l:entries += 1
      if l:item.type ==? 'E'
        let l:errors += 1
      elseif l:item.type ==? 'W'
        let l:warnings += 1
      endif
    endif
  endfor

  let s:qf_entries = l:entries
  let s:qf_errors = l:errors
  let s:qf_warnings = l:warnings

  if s:qf_entries > 0
    echom printf("[s:QFListCount] Entries: %d | Errors: %d | Warnings: %d", s:qf_entries, s:qf_errors, s:qf_warnings)
  else
    echom '[s:QFListCount] Quickfix list is empty'
  endif
endfunction

function! QFTabline()
  return (s:qf_entries > 0) ? printf("E:%d|W:%d", s:qf_errors, s:qf_warnings) : 'E:_|W:_'
endfunction

augroup QFUpdate
  autocmd!
  autocmd QuickFixCmdPost [^l]* call s:QFListCount()
augroup END

command! Ccount call s:QFListCount()

"------------------------------
" Build
"
" `:redraw!` seems to be needed on my current linux terminal emulator
function! s:BuildAndDebug()
  " Create build directory
  let l:build_dir = expand("%:p:h") . "/build"
  if !isdirectory(l:build_dir)
    call mkdir(l:build_dir, "p")
  endif

  let l:prg_path = l:build_dir . "/" . expand("%:t:r")

  execute 'w'
  execute 'silent make!'

  if s:qf_errors < 1
    if s:is_win
      " Lauch RAD Debugger on Windows
      call system(printf("start raddbg.exe \"%s.exe\"", l:prg_path))
      echo '==> Build Successful (s:qf_entries:' . s:qf_entries . ') - RAD Debugger Launched <=='
      if s:qf_entries < 1
        execute 'cclose'
      endif
    else
      " Launch GDB in a new terminal
      let l:gdb_args = '-tui -ex "layout split" -ex "set print pretty" -ex "set logging file gdb_out.log" -ex "set logging enable on"'
      call system(printf("xfce4-terminal --execute gdb %s \"%s\" &", l:gdb_args, l:prg_path))
      echo '==> Build Successful (s:qf_entries:' . s:qf_entries . ') - GDB Launched <=='
      execute 'redraw!'
    endif
  else
    echohl ErrorMsg | echo '==> Build Failed <==' | echohl None
    execute 'cw'
  endif
endfunction

function! s:BuildAndCheck()
 " Create build directory
  let l:build_dir = expand("%:p:h") . "/build"
  if !isdirectory(l:build_dir)
    call mkdir(l:build_dir, "p")
  endif

  execute 'w'
  execute 'silent make!'

  if !s:is_win
    execute 'redraw!'
  endif

  if s:qf_errors > 0
    let @/ = "error"
    execute 'copen'
    echohl ErrorMsg | echo '==> Build Failed <==' | echohl None
  elseif s:qf_warnings > 0
    echohl WarningMsg | echo '==> Build finished with ' . s:qf_entries . ' issue(s) <==' | echohl None
  else
    echohl OkMsg | echo '==> Build Successful <==' | echohl None
    execute 'cclose'
  endif
endfunction

command! Raddbg call s:BuildAndDebug()
command! Build call s:BuildAndCheck()
nnoremap <F10> :Raddbg<CR>
nnoremap <F5> :Build<CR>


