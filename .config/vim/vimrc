" https://kitsugo.com/guide/netrw-improvements/?__goaway_challenge=meta-refresh&__goaway_id=a3b5e9008f844f6fb641379753b93a64&__goaway_referer=https%3A%2F%2Fwww.google.com%2F
function! s:NazrwCopyMove(move)
  if a:move
    let l:cmd = (s:is_win) ? 'move /Y' : 'mv -f'
  else
    let l:cmd = (s:is_win) ? 'copy /Y' : 'cp -f'
  endif

  " Choices: [1]'Yes', [2]'No', [3]'All' (:help confirm() -> [0] is for <Esc>, CTRL-C)
  let l:choice = 2

  let l:mark_list = netrw#Expose("netrwmarkfilelist")
  if empty(l:mark_list)
    echom '==> Mark list in empty <=='
    return
  endif
  for l:curr_file in l:mark_list
    let l:src_path = fnamemodify(l:curr_file, ':p')
    let l:dest_path = fnamemodify(b:netrw_curdir . '/' . fnamemodify(l:src_path, ':t'), ':p')

    " Check for overwrite and escape ([0] <Esc>)
    if filereadable(l:dest_path) && l:choice != 3
      let l:choice = confirm("Confirm overwrite of file [" . l:dest_path . ']?', "&yes\n&no\n&all")
      if l:choice == 0
        echom '==> Copy aborted. <=='
        break
      elseif l:choice == 2
        continue
      endif
    endif

    if s:is_win
      " Change forward slashes to backward slashes
      let l:src_path = tr(l:src_path, '/', '\')
      let l:dest_path = tr(l:dest_path, '/', '\')
    endif

    echom '$ ' . l:cmd . " \"" . l:src_path . "\" \"" . l:dest_path . "\""
    call system(l:cmd . " \"" . l:src_path . "\" \"" . l:dest_path . "\"")
  endfor

  execute 'normal mu'
endfunction

function! s:NazrwShowMarkList()
  let l:mark_list = netrw#Expose("netrwmarkfilelist")
  if type(l:mark_list) == type("") || empty(l:mark_list)
    echohl WarningMsg | echo '==> Mark list is empty <==' | echohl None
  else
    echohl Directory | echo '[' . len(l:mark_list) . '] marks:' | echohl None
    echo join(l:mark_list, "\n")
  endif
endfunction

