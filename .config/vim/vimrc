command! Makeclear let &makeprg='' | let s:makeprg_cmd_name = '____' | redrawtabline

function! s:SetMakeprg(name, cmd)
  let s:makeprg_cmd_name = a:name
  let &makeprg = a:cmd
  redrawtabline
  echo '==> ' . a:name . ' [' . a:cmd . '] set as &makeprg <=='
endfunction

" C debug build (default for .c)
command! Make call s:SetMakeprg('Make', printf('%s -g -O0 %s "%%:p" -o "%s"', s:c_compiler, s:c_flags, s:out_path))

" C final build
command! MakeRelease call s:SetMakeprg('MakeRelease', printf('%s -O3 %s "%%:p" -o "%s"', s:c_compiler, s:c_flags, s:out_path))

" C++ debug build (default for .cpp)
command! Makecpp call s:SetMakeprg('Makecpp', printf('%s -g -O0 %s "%%:p" -o "%s"', s:cpp_compiler, s:cpp_flags, s:out_path))

" C++ final build
command! MakecppRelease call s:SetMakeprg('MakecppRelease', printf('%s -O3 %s "%%:p" -o "%s"', s:cpp_compiler, s:cpp_flags, s:out_path))

" C fsyntax-only
command! Makefsyntax call s:SetMakeprg('Makefsyntax', printf('%s -fsyntax-only %s "%%:p"', s:c_compiler, s:c_flags))

" C++ fsyntax-only
command! Makecppfsyntax call s:SetMakeprg('Makecppfsyntax', printf('%s -fsyntax-only %s "%%:p"', s:cpp_compiler, s:cpp_flags))

" MSVC debug build (need vcvars env)
command! Makecl call s:SetMakeprg('Makecl', 'cd build && cl /Zi /Od /W4 "%:p"')

