function! GerminalHere(mode)
  let l:head_dir = expand('%:p:h:S')
  if &filetype == 'netrw'
    let l:head_dir = shellescape(b:netrw_curdir)
  endif
  call GlobalTerminal(a:mode)
  call feedkeys("i\<C-c> cd " . l:head_dir . "\<CR>\<Esc>", 't')
endfunction

