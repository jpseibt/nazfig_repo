" Base and warning flags
let s:common_flags = "-Wall -Wextra -Wpedantic"
let s:c_flags = s:common_flags . " -std=c99"
let s:cpp_flags = s:common_flags . " -std=c++03"

" Output program path
let s:out_path = "%:p:h" . "/build/" . "%:t:r" . (s:is_win ? ".exe" : "")


"------------------------------
" Commands (makeprg)
"
" C debug build (default for .c)
command! Make execute printf("let &makeprg = '%s -g -O0 %s \"%%:p\" -o \"%s\"'", s:c_compiler, s:c_flags, s:out_path)

" C final build
command! MakeRelease execute printf("let &makeprg = '%s -O3 %s \"%%:p\" -o \"%s\"'", s:c_compiler, s:c_flags, s:out_path)

" C++ debug build (default for .cpp)
command! Makecpp execute printf("let &makeprg = '%s -g -O0 %s \"%%:p\" -o \"%s\"'", s:cpp_compiler, s:cpp_flags, s:out_path)

" C++ final build
command! MakecppRelease execute printf("let &makeprg = '%s -O3 %s \"%%:p\" -o \"%s\"'", s:cpp_compiler, s:cpp_flags, s:out_path)

" C fsyntax-only
command! Makefsyntax execute printf("let &makeprg = '%s -fsyntax-only %s \"%%:p\"'", s:c_compiler, s:c_flags)

" C++ fsyntax-only
command! Makecppfsyntax execute printf("let &makeprg = '%s -fsyntax-only %s \"%%:p\"'", s:cpp_compiler, s:cpp_flags)

" MSVC debug build (need vcvars env)
command! Makecl let &makeprg = 'cd build && cl /Zi /Od /W4 "%:p"'

" MSVC final build (need vcvars env)
command! MakeclRelease let &makeprg = 'cd build && cl /O2 /W4 "%:p"'

" Copy makeprg to clipboard
command! Cpmakeprg :let @+ = &makeprg | echo '==> [' . @+ . '] copied to the clipboard <=='

" Copy expanded makeprg to clipboard
command! Cpmake :let @+ = expandcmd(&makeprg) | echo '==> [' . @+ . '] copied to the clipboard <=='

autocmd FileType c Makefsyntax
autocmd FileType cpp Makecppfsyntax


"------------------------------
" Quickfix List
"
" Prepend to &errorformat regex to parse 'type' correctly in Clang/GCC
set errorformat^=%f:%l:%c:\ %t%*[^:]:\ %m

let g:qf_entries = 0
let g:qf_errors = 0
let g:qf_warnings = 0

function! s:QFListCount()
  let l:qf_list = getqflist()

  let l:entries = 0
  let l:errors = 0
  let l:warnings = 0

  for l:item in l:qf_list
    if l:item.valid
      let l:entries += 1
      if l:item.type ==? 'E'
        let l:errors += 1
      elseif l:item.type ==? 'W'
        let l:warnings += 1
      endif
    endif
  endfor

  let g:qf_entries = l:entries
  let g:qf_errors = l:errors
  let g:qf_warnings = l:warnings

  if g:qf_entries > 0
    echom printf("[s:QFListCount] Entries: %d | Errors: %d | Warnings: %d", g:qf_entries, g:qf_errors, g:qf_warnings)
  else
    echom "[s:QFListCount] Quickfix list is empty"
  endif
endfunction

function! QFStatusline()
  if g:qf_entries < 1
    return ""
  endif
  return printf("[E:%d|W:%d]", g:qf_errors, g:qf_warnings)
endfunction

augroup QFUpdate
  autocmd!
  autocmd QuickFixCmdPost [^l]* call s:QFListCount()
augroup END

command! Ccount call s:QFListCount()
"Ccount " Run it on every vimrc source


"------------------------------
" Build
"
" `:redraw!` seems to be needed on my current linux terminal emulator
function! s:BuildAndDebug()
  " Create build directory
  let l:build_dir = expand("%:p:h") . "/build"
  if !isdirectory(l:build_dir)
    call mkdir(l:build_dir, "p")
  endif

  let l:prg_path = l:build_dir . "/" . expand("%:t:r")

  execute 'w'
  execute 'silent make!'

  if g:qf_errors < 1
    if s:is_win
      " Lauch RAD Debugger on Windows
      call system(printf("start raddbg.exe \"%s.exe\"", l:prg_path))
      echo "==> Build Successful (g:qf_entries:" . g:qf_entries . ") - RAD Debugger Launched <=="
      if g:qf_entries < 1
        execute 'cclose'
      endif
    else
      " Launch GDB in a new terminal
      let l:gdb_args = '-tui -ex "layout split" -ex "set print pretty" -ex "set logging file gdb_out.log" -ex "set logging enable on"'
      call system(printf("xfce4-terminal --execute gdb %s \"%s\" &", l:gdb_args, l:prg_path))
      echo "==> Build Successful (g:qf_entries:" . g:qf_entries . ") - GDB Launched <=="
      execute 'redraw!'
    endif
  else
    echohl ErrorMsg | echo "==> Build Failed <==" | echohl None
    execute 'cw'
  endif
endfunction

function! s:BuildAndCheck()
 " Create build directory
  let l:build_dir = expand("%:p:h") . "/build"
  if !isdirectory(l:build_dir)
    call mkdir(l:build_dir, "p")
  endif

  execute 'w'
  execute 'silent make!'

  if !s:is_win
    execute 'redraw!'
  endif

  if g:qf_errors > 0
    let @/ = "error"
    execute 'copen'
    echohl ErrorMsg | echo "==> Build Failed <==" | echohl None
  elseif g:qf_warnings > 0
    echo "==> Build finished with " . g:qf_entries . " issue(s) <=="
  else
    echohl WarningMsg | echo "==> Build Successful <==" | echohl None
    execute 'cclose'
  endif
endfunction

command! Raddbg call s:BuildAndDebug()
command! Build call s:BuildAndCheck()
nnoremap <F10> :Raddbg<CR>
nnoremap <F5> :Build<CR>


