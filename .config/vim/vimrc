"------------------------------
" Marked files list
"
if !exists('s:nazrw_mark_list')
  let s:nazrw_mark_list = []
endif

function! s:NazrwUpdateMarkList()
  let s:nazrw_mark_list = netrw#Expose("netrwmarkfilelist")
  if type(s:nazrw_mark_list) == type("") || empty(s:nazrw_mark_list)
    let s:nazrw_mark_list = []
  endif
  redrawstatus
endfunction

function! s:NazrwShowMarkList(last)
  call s:NazrwUpdateMarkList()
  if empty(s:nazrw_mark_list)
    echohl Directory | echo '==> Mark list is empty <==' | echohl None
    return
  else
    " copy the mark list with relative paths
    let l:rel_mark_list = map(copy(s:nazrw_mark_list), "fnamemodify(v:val, ':.')")
    let l:len_mark_list = len(l:rel_mark_list)

    if a:last
      echohl Directory | echo '* ' . l:rel_mark_list[l:len_mark_list - 1] . ' ('. (l:len_mark_list - 1) . ' more...)' | echohl None
    else
      echohl Directory | echo '[' . len(l:rel_mark_list) . '] marks:' | echohl None
      echo '* ' . join(l:rel_mark_list, "\n* ")
    endif
  endif
endfunction

"------------------------------
" Copy / Move
"
function! s:GetCopyMoveCmd(is_move, is_dir)
  if a:is_move
    if s:is_win
      return 'move /Y'
    else
      return 'mv -f'
    endif
  else
    if s:is_win
      return (a:is_dir) ? 'xcopy /E /I /Q /H /Y' : 'copy /Y'
    else
      return 'cp -rf'
    endif
  endif
endfunction

function! s:NazrwCopyMove(is_move)
  call s:NazrwUpdateMarkList()
  if empty(s:nazrw_mark_list)
    echohl Directory | echo '==> Mark list is empty <==' | echohl None
    return
  endif

  " Choices: [1]'Yes', [2]'No', [3]'All' (:help confirm() -> [0] is for <Esc>, CTRL-C)
  let l:choice = 2

  for l:curr_file in s:nazrw_mark_list
    " Use regex to remove trailing slashes ('/' or '\'), so `:t` also return directories (for '~/dir//', tail is 'dir')
    let l:src_path = fnamemodify(l:curr_file, ':p')
    let l:src_path = substitute(l:src_path, '[/\\]\+$', '', '')
    let l:dest_path = b:netrw_curdir . '/' . fnamemodify(l:src_path, ':t')

    let l:cmd = s:GetCopyMoveCmd(a:is_move, isdirectory(l:src_path))

"[DEBUG]echom 'l:cmd: '. l:cmd
"[DEBUG]echom 'l:src_path: '. l:src_path
"[DEBUG]echom 'l:dest_path: ' . l:dest_path

    " Check for overwrite and escape ([0] <Esc>)
    if (filereadable(l:dest_path) || isdirectory(l:dest_path)) && l:choice != 3
      let l:choice = confirm("Confirm overwrite of file [" . l:dest_path . ']?', "&yes\n&no\n&all")
      if l:choice == 0
        echom '[s:NazrwCopyMove()] Aborted.'
        break
      elseif l:choice == 2
        continue
      endif
    endif

    let l:src_path = ShellEscape(l:src_path)
    let l:dest_path = ShellEscape(l:dest_path)

    echom '[s:NazrwCopyMove()]$ ' . l:cmd . ' ' . l:src_path . ' ' . l:dest_path
    call system(l:cmd . ' ' . l:src_path . ' ' . l:dest_path)
  endfor

  call netrw#Modify("netrwmarkfilelist", [])
  let s:nazrw_mark_list = []

  execute "normal \<C-l>"
endfunction

"------------------------------
" Archiving
"
let s:default_archive_ext = 'zip'

"NOTE: Implement archive path directory creation, if doesn't exist
function! s:NazrwArchive()
  call s:NazrwUpdateMarkList()
  if empty(s:nazrw_mark_list)
    echohl Directory | echo '==> Mark list is empty <==' | echohl None
    return
  endif

  let l:cmd = 'tar -acf '

  " Prompt for the archive file path. If no extention is given, a default one is assigned (input() doesn't add a '\n')
  let l:archive_path = input('Archive path: ', b:netrw_curdir . '/nazrw_archive.' . s:default_archive_ext, 'file')
  echo "\n"

  if empty(l:archive_path)
    " input() return an empty string for <Esc>
    echom '[s:NazrwArchive()] Aborted.'
    return
  elseif empty(fnamemodify(l:archive_path, ':e'))
    " No archive extension provided, set default archiving method
    let l:archive_path .= '.' . s:default_archive_ext
  endif

  let l:cmd .= ShellEscape(l:archive_path)

  " Loop through the files in the mark list and append ` -C file_head file_tail` to the tar command
  for l:curr_file in s:nazrw_mark_list
    " Use regex to remove trailing slashes ('/' or '\'), so `:t` also return directories (for '~/dir//', tail is 'dir')
    let l:curr_file = substitute(l:curr_file, '[/\\]\+$', '', '')
    let l:cmd .= ' -C ' . ShellEscape(fnamemodify(l:curr_file, ':h')) . ' ' . ShellEscape(fnamemodify(l:curr_file, ':t'))
  endfor

  echom '[s:NazrwArchive()]$ ' . l:cmd
  call system(l:cmd)

  call netrw#Modify("netrwmarkfilelist", [])
  let s:nazrw_mark_list = []

  execute "normal \<C-l>"
endfunction

function! s:NazrwExtract()
